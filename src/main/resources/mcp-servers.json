{
  "mcpServers": {
    "fitness-db-mcp-server": {
      "command": "java",
      "args": [
        "-Dspring.ai.mcp.server.stdio=true",
        "-Dspring.main.web-application-type=none",
        "-Dlogging.pattern.console=",
        "-jar",
        "fitness-db-mcp-server/target/fitness-db-mcp-server-0.0.1-SNAPSHOT.jar"
      ],
      "env": {
        "SPRING_DATASOURCE_URL": "jdbc:mysql://localhost:3306/fitness_db?useSSL=false&serverTimezone=UTC&characterEncoding=utf8",
        "SPRING_DATASOURCE_USERNAME": "fitness_user",
        "SPRING_DATASOURCE_PASSWORD": "fitness_pass"
      }
    }
  }
}
